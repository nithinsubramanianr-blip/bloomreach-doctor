# Personalization Performance Doctor — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Bloomreach Discovery REST API
BLOOMREACH_DISCOVERY_API_KEY=your_discovery_api_key_here

# Bloomreach Engagement API
BLOOMREACH_ENGAGEMENT_API_KEY=your_engagement_api_key_here

# Loomi Connect MCP Endpoints (provided via hackathon Slack — check #sandbox-support)
BLOOMREACH_MCP_MARKETING_URL=https://loomi-connect.bloomreach.com/marketing/mcp
BLOOMREACH_MCP_ANALYTICS_URL=https://loomi-connect.bloomreach.com/analytics/mcp

# Anthropic API (for Module C — NL Chat Interface)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Next.js PLP (M5) — Discovery search endpoint
NEXT_PUBLIC_DISCOVERY_ENDPOINT=https://core.dxpapi.com/api/v1/core/

# Data source: 'synthetic' (default) or 'live'
DATA_SOURCE=synthetic

# Claude model override (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Demo brand label shown in UI
VITE_APP_DEMO_BRAND=Kendra Scott
