# Personalization Performance Doctor — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Bloomreach Discovery REST API
BLOOMREACH_DISCOVERY_API_KEY=your_discovery_api_key_here

# Bloomreach Engagement API
# Set to the Bearer token from your Loomi MCP session (whoami.access_token)
BLOOMREACH_ENGAGEMENT_API_KEY=your_engagement_bearer_token_here

# Bloomreach Engagement — base URL and project identifiers
BLOOMREACH_ENGAGEMENT_BASE_URL=<URL>
BLOOMREACH_PROJECT_ID=<PROJECT_ID>
BLOOMREACH_CATALOG_ID=<CATALOG_ID>

# Loomi MCP server — browser PLP uses this for live catalog queries via JSON-RPC.
# The bearer token (BLOOMREACH_ENGAGEMENT_API_KEY) authenticates against this URL.
BLOOMREACH_LOOMI_MCP_URL=<URL>

# Loomi Connect MCP Endpoints (legacy placeholders — live path now uses BLOOMREACH_ENGAGEMENT_BASE_URL)
BLOOMREACH_MCP_MARKETING_URL=<URL>
BLOOMREACH_MCP_ANALYTICS_URL=<URL>

# Anthropic API (for Module C — NL Chat Interface)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# React PLP (M5) — Discovery search endpoint (must be VITE_ prefixed for client exposure)
VITE_DISCOVERY_ENDPOINT=<URL>
# Discovery account ID and domain key (from BR dashboard — required for live search)
VITE_DISCOVERY_ACCOUNT_ID=
VITE_DISCOVERY_DOMAIN_KEY=

# Data source: 'synthetic' (default) or 'live'
DATA_SOURCE=live

# Claude model override (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Demo brand label shown in UI
VITE_APP_DEMO_BRAND=Bounteous x Accolite

# Bloomreach Loomi Conversations Server (MCP). Public prototype endpoint —
# no API key required.
BLOOMREACH_LOOMI_CONVERSATIONS_URL=<URL>

# ---------------------------------------------------------------------------
# Feature toggles (default: false → current demo behaviour preserved)
# Set to "true" to enable. Read by both Node (M1/M3) and browser bundle.
# ---------------------------------------------------------------------------
# Module C — restore Claude native tool use (tool_choice:auto) per Invariant #6.
# When true, ANTHROPIC_API_KEY must also be set; calls are routed through
# the Vite /anthropic-api proxy so the key never enters the client bundle.
FEATURE_NATIVE_CLAUDE_TOOLS=false

# Module B — anchor each persona to a real live customer from Engagement
# (pulls list_customers_in_segment + list_customer_events).
FEATURE_PERSONA_PROVENANCE=false

# PRS Scorecard — Foundation Health sidebar that flags zero predictions /
# recommendations / scenarios in the live project.
FEATURE_FOUNDATION_GAP=false

# PRS Scorecard — Untapped Segment Opportunities card (live segments that
# exist in Engagement but aren't bound to any Discovery rule).
FEATURE_SEGMENT_OPPORTUNITIES=false

# Dashboard — Export Doctor's Report (PDF) button in the header.
FEATURE_DOCTORS_REPORT=false
